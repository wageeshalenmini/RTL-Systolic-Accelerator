`timescale 1ns/1ps

module tb_processing_element();

    logic clk, reset_n, en;
    logic [15:0] data_in, weight_in, data_out, weight_out;
    logic [31:0] acc_out;

    // Instantiate UUT
    processing_element uut (.*); // Uses '.*' to auto-connect matching names

    // Clock Generation
    initial clk = 0;
    always #5 clk = ~clk;

    initial begin
        // --- Setup Transcript View ---
        $display("\n[MODELSIM TRANSCRIPT START]");
        $display("==================================================");
        $display(" TIME |  DATA_IN |  WT_IN  |  ACC_OUT |  DATA_OUT");
        $display("------|----------|---------|----------|----------");

        // Initialize
        reset_n = 0; en = 0; data_in = 0; weight_in = 0;
        #20 reset_n = 1;
        @(posedge clk); en = 1;

        // Cycle 1: Input 2 and 5
        data_in = 16'd2; weight_in = 16'd5;
        @(posedge clk);
        // $strobe prints at the end of the current clock cycle
        $strobe("%4t  |  %7d | %7d | %8d | %8d", $time, data_in, weight_in, acc_out, data_out);
        
        // Cycle 2: Input 3 and 4
        data_in = 16'd3; weight_in = 16'd4;
        @(posedge clk);
        $strobe("%4t  |  %7d | %7d | %8d | %8d", $time, data_in, weight_in, acc_out, data_out);
        
        // Final Check
        #1; 
        $display("--------------------------------------------------");
        if (acc_out == 32'd22) 
            $display(" RESULT: SUCCESS (22) Verified in Transcript.");
        else 
            $display(" RESULT: ERROR! Got %d", acc_out);
        $display("==================================================\n");

        #20 $stop;
    end
endmodule